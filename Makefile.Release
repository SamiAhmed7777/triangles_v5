####### Build rules

first: all
all: Makefile.Release  release/triangles-qt.exe

release/triangles-qt.exe: E:/repos/triangles/src/leveldb/libleveldb.a C:/msys64/mingw64/lib/libQt5Widgets.dll.a C:/msys64/mingw64/lib/libQt5Gui.dll.a C:/msys64/mingw64/lib/libQt5Core.dll.a C:/msys64/mingw64/lib/libqtmain.a build/ui_coincontroldialog.h build/ui_sendcoinsdialog.h build/ui_addressbookpage.h build/ui_aboutdialog.h build/ui_editaddressdialog.h build/ui_transactiondescdialog.h build/ui_overviewpage.h build/ui_sendcoinsentry.h build/ui_askpassphrasedialog.h build/ui_rpcconsole.h build/ui_optionsdialog.h build/ui_messagepage.h build/ui_sendmessagesentry.h build/ui_sendmessagesdialog.h build/ui_mrichtextedit.h build/ui_mainwindow.h build/ui_signmessagepage.h build/ui_verifymessagepage.h build/ui_transactionspage.h $(OBJECTS) build/triangles-qt_res.o
	$(LINKER) $(LFLAGS) -o $(DESTDIR_TARGET) @object_script.triangles-qt.Release  $(LIBS)

build/triangles-qt_res.o: src/qt/res/triangles-qt.rc src/clientversion.h
	windres -i src/qt/res/triangles-qt.rc -o build/triangles-qt_res.o --include-dir=./src/qt/res $(DEFINES)

qmake: FORCE
	@$(QMAKE) -o Makefile.Release triangles-qt.pro

